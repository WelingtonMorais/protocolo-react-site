#VITE_API_URL=http://localhost:3000/api
VITE_API_URL=https://requestwm.vps-kinghost.net/api
# GA4 Web Data Stream (público no browser). No servidor de build, defina a mesma variável antes de `vite build`.
VITE_GA4_MEASUREMENT_ID=G-ZH23QP309T
# Tag de conversão Google Ads (gtag config AW-...). Um único carregamento de gtag.js com o GA4.
VITE_GOOGLE_ADS_ID=AW-18098857521
# Conversão Ads: send_to do snippet (conta/rotulo). Só dispare onde fizer sentido no app.
VITE_GOOGLE_ADS_CONVERSION_SEND_TO=AW-18098857521/dLCuCNnA350cELHMmrZD
# GTM deve ser definido no ambiente de produção para orquestrar eventos e conversões.
# Exemplo: VITE_GTM_ID=GTM-XXXXXXX
VITE_GTM_ID=GTM-WMV8DW8K
